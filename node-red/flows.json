    {
        "id": "b9db70cc0cb2fa96",
        "type": "function",
        "z": "3c3a538362403657",
        "name": "Acumula",
        "func": "// Recupera o estado atual ou inicia com valores padrão\nlet dados = context.get(\"dados\") || {\n    temperatura: null,\n    umidade: null,\n    pressao: null\n};\n\n// Atualiza o dado específico baseado no tópico MQTT\nif (msg.topic === \"iot/temperatura\") dados.temperatura = Number(msg.payload);\nif (msg.topic === \"iot/umidade\")     dados.umidade = Number(msg.payload);\nif (msg.topic === \"iot/pressao\")     dados.pressao = Number(msg.payload);\n\n// Salva o estado atualizado no contexto\ncontext.set(\"dados\", dados);\n\n// Só envia se todos os três campos já tiverem recebido pelo menos um valor\nif (\n    dados.temperatura !== null &&\n    dados.umidade !== null &&\n    dados.pressao !== null\n) {\n    // Clona o objeto para evitar problemas de concorrência\n    msg.payload = { ...dados }; \n    msg.payload.timestamp = new Date();\n    \n    return msg;\n}\n\nreturn null;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 940,
        "wires": [
            [
                "30ebb3d8e27ffec2"
            ]
        ]
    },
    {
        "id": "30ebb3d8e27ffec2",
        "type": "function",
        "z": "3c3a538362403657",
        "name": "MySql",
        "func": "let d = msg.payload;\n\n\nmsg.topic = `INSERT INTO sensores (temperatura, umidade, pressao, data_hora) VALUES (${d.temperatura}, ${d.umidade}, ${d.pressao}, NOW());`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 940,
        "wires": [
