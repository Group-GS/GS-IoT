    {
        "id": "1e984e7d285dc23d",
        "type": "function",
        "z": "flow_iot",
        "name": "Acumula",
        "func": "let dados = context.get(\"dados\") || {\n    temperatura: null,\n    umidade: null,\n    pressao: null\n};\n\nif (msg.topic === \"iot/temperatura\") {\n    dados.temperatura = Number(msg.payload);\n}\n\nif (msg.topic === \"iot/umidade\") {\n    dados.umidade = Number(msg.payload);\n}\n\nif (msg.topic === \"iot/pressao\") {\n    dados.pressao = Number(msg.payload);\n}\n\ncontext.set(\"dados\", dados);\n\nif (\n    dados.temperatura !== null &&\n    dados.umidade !== null &&\n    dados.pressao !== null\n) {\n    msg.payload = dados;\n\n    context.set(\"dados\", {\n        temperatura: null,\n        umidade: null,\n        pressao: null\n    });\n\n    return msg;\n}\n\nmsg.payload.timestamp = new Date();\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 940,
        "wires": [
            [
                "145bca1a2f9c0466"
            ]
        ]
    },
